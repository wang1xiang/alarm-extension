{
  "manifest_version": 3,
  "name": "闹钟 & 倒计时",
  "version": "1.0.0",
  "description": "为您的浏览器提供闹钟和倒计时功能",
  "permissions": [
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "file:///*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "闹钟 & 倒计时",
    "default_icon": {
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "icons": {
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/sounds/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
